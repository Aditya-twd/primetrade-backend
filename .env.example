# ── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────
# Local:  mongodb://localhost:27017/primetrade
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/primetrade?retryWrites=true&w=majority
# NOTE: if your password has special chars (@ : / # etc.), URL-encode them (e.g. # -> %23).
MONGO_URI=mongodb://localhost:27017/primetrade

# ── JWT secrets (CHANGE THESE in production) ─────────────
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── CORS (comma-separated allow-list) ────────────────────
CORS_ORIGIN=http://localhost:5173,https://primetrade-frontend-pied.vercel.app

# ── Seed admin (created on first boot if absent) ─────────
# IMPORTANT: override SEED_ADMIN_PASSWORD in production — do not ship this
# public default to a live deployment.
SEED_ADMIN_EMAIL=admin@primetrade.ai
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=Site Admin
